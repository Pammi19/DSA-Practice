class Solution {
  public:
    bool isSubset(vector<int> &a, vector<int> &b) {
        unordered_map<int, int> freq;

        // Count frequency of elements in a
        for (int x : a) {
            freq[x]++;
        }

        // Check for b
        for (int x : b) {
            if (freq[x] == 0) {
                return false;
            }
            freq[x]--;
        }

        return true;
    }
};
Time: O(n + m)
Space: O(n)

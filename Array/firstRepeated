#include <vector>
#include <unordered_map>
using namespace std;

class Solution {
public:
    int firstRepeated(vector<int> &arr) {
        unordered_map<int, int> firstIndex;
        unordered_map<int, int> freq;

        // Step 1: Store first occurrence and frequency
        for (int i = 0; i < arr.size(); i++) {
            if (firstIndex.find(arr[i]) == firstIndex.end()) {
                firstIndex[arr[i]] = i + 1; // 1-based index
            }
            freq[arr[i]]++;
        }

        // Step 2: Find minimum index among repeating elements
        int ans = INT_MAX;

        for (auto &it : freq) {
            if (it.second > 1) {
                ans = min(ans, firstIndex[it.first]);
            }
        }

        return (ans == INT_MAX) ? -1 : ans;
    }
};
Time: O(n)
Space: O(n)

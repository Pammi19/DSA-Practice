#include <stack>
using namespace std;

class SpecialStack {
    stack<long long> st;
    long long mini;

  public:
    SpecialStack() {
        // initialize
        while(!st.empty()) st.pop();
    }

    void push(int x) {
        if (st.empty()) {
            st.push(x);
            mini = x;
        } else {
            if (x >= mini) {
                st.push(x);
            } else {
                // encode value
                st.push(2LL * x - mini);
                mini = x;
            }
        }
    }

    void pop() {
        if (st.empty()) return;

        long long top = st.top();
        st.pop();

        if (top < mini) {
            // decode previous minimum
            mini = 2 * mini - top;
        }
    }

    int peek() {
        if (st.empty()) return -1;

        long long top = st.top();
        if (top < mini)
            return mini;
        return top;
    }

    bool isEmpty() {
        return st.empty();
    }

    int getMin() {
        if (st.empty()) return -1;
        return mini;
    }
};
T.C=O(1) //FOR ALL FUN
Space Complexity O(n)

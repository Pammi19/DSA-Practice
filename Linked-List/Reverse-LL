class Solution {
  public:
    Node* reverseList(Node* head) {
        Node* prev = NULL;
        Node* curr = head;
        Node* next = NULL;

        while(curr != NULL) {
            next = curr->next;   // store next node
            curr->next = prev;   // reverse link
            prev = curr;         // move prev
            curr = next;         // move curr
        }

        return prev;  // new head
    }
};

Time Complexity: O(n)

Space Complexity: O(1)

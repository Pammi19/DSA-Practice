class Solution {
  public:
    bool isPalindrome(Node *head) {
        if (head == NULL || head->next == NULL) return true;

        // Step 1: Find middle using slow & fast pointer
        Node* slow = head;
        Node* fast = head;

        while (fast->next != NULL && fast->next->next != NULL) {
            slow = slow->next;
            fast = fast->next->next;
        }

        // Step 2: Reverse second half
        Node* prev = NULL;
        Node* curr = slow->next;
        while (curr != NULL) {
            Node* nextNode = curr->next;
            curr->next = prev;
            prev = curr;
            curr = nextNode;
        }

        // Step 3: Compare both halves
        Node* first = head;
        Node* second = prev;

        while (second != NULL) {
            if (first->data != second->data) {
                return false;
            }
            first = first->next;
            second = second->next;
        }

        return true;
    }
    
 Time: O(n)
Space: O(1)

};

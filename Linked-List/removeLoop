class Solution {
  public:
    void removeLoop(Node* head) {
       
    Node *slow = head, *fast = head;

    // Step 1: Detect loop
    while (fast != NULL && fast->next != NULL) {
        slow = slow->next;
        fast = fast->next->next;

        if (slow == fast) {
            break;
        }
    }

    // No loop
    if (slow != fast) return;

    // Step 2: Move slow to head
    slow = head;

    // If loop starts at head
    if (slow == fast) {
        while (fast->next != slow)
            fast = fast->next;
    } 
    else {
        while (slow->next != fast->next) {
            slow = slow->next;
            fast = fast->next;
        }
    }

    // Step 3: Remove loop
    fast->next = NULL;
}
        
    
};

//Time Complexity: O(n)
//Space Complexity: O(1)
